{
  "name": "finansight",
  "version": "1.0.0",
  "description": "Aplikasi perencana keuangan pribadi berbasis web yang dapat di-build ke Android/iOS menggunakan Capacitor JS.",
  "main": "app.js",
  "scripts": {
    "build": "node -e \"const fs=require('fs');if(!fs.existsSync('www'))fs.mkdirSync('www');fs.copyFileSync('index.html','www/index.html');fs.copyFileSync('app.js','www/app.js');\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "sync": "npx cap sync android",
    "prepare": "npm run build",
    "open:android": "npx cap open android",
    "clean": "node -e \"const fs=require('fs');if(fs.existsSync('www'))fs.rmSync('www',{recursive:true,force:true});\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuumuu/Finansight.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/yuumuu/Finansight/issues"
  },
  "homepage": "https://github.com/yuumuu/Finansight#readme",
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}